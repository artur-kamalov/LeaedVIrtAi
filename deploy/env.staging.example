NODE_ENV=production
APP_ENV=staging
APP_URL=https://leadvirt.com
API_URL=https://leadvirt.com
PUBLIC_APP_NAME=LeadVirt.ai

NEXT_PUBLIC_API_URL=https://leadvirt.com/api
NEXT_PUBLIC_APP_URL=https://leadvirt.com
NEXT_PUBLIC_WEB_URL=https://leadvirt.com
NEXT_PUBLIC_DEMO_MODE=false
NEXT_PUBLIC_TELEGRAM_LOGIN_BOT=LeadVirtAi_bot

PORT=4001
CORS_ORIGINS=https://leadvirt.com,https://www.leadvirt.com
LOG_LEVEL=info

POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://leadvirt:change-me@postgres:5432/leadvirt?schema=public
REDIS_URL=redis://redis:6379

AUTH_MODE=local
AUTH_COOKIE_SECURE=true
AUTH_CREDENTIALS_ENABLED=false
AUTH_RATE_LIMIT_DISABLED=false
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me
AUTH_2FA_ENCRYPTION_KEY=change-me
ENCRYPTION_KEY=change-me

AI_PROVIDER=openai
AI_DEFAULT_MODEL=gpt-5.5
AI_REASONING_EFFORT=low
AI_VERBOSITY=low
AI_REPLY_MODE=queue
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_ENABLE_REAL_PROVIDER=true
AI_TENANT_DAILY_TOKEN_BUDGET=0
AI_TENANT_MONTHLY_TOKEN_BUDGET=0

RAG_QDRANT_ENABLED=true
RAG_QDRANT_URL=http://qdrant:6333
RAG_QDRANT_API_KEY=
RAG_QDRANT_COLLECTION=leadvirt_knowledge

STORAGE_PROVIDER=local
EMAIL_PROVIDER=manual
EMAIL_FROM=LeadVirt.ai <noreply@leadvirt.ai>
BILLING_MODE=manual
BILLING_PROVIDER=manual

TELEGRAM_BOT_TOKEN=
TELEGRAM_LOGIN_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
GENERIC_WEBHOOK_SECRET=

SENTRY_DSN=
SENTRY_ENVIRONMENT=staging
WORKER_METRICS_ENABLED=true
WORKER_METRICS_PORT=4002
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://tempo:4318/v1/traces
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

FEATURE_REALTIME=true
FEATURE_BILLING=false
FEATURE_AI_REAL_PROVIDER=true
FEATURE_TELEGRAM=true
FEATURE_WEBSITE_WIDGET=true
WORKER_ENABLE_PROCESSORS=true
WORKER_JOB_TIMEOUT_MS=30000
WORKER_DLQ_INSPECT_LIMIT=20
