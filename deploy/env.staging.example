NODE_ENV=production
APP_ENV=staging
APP_URL=https://leadvirt.com
API_URL=https://leadvirt.com
PUBLIC_APP_NAME=LeadVirt.ai

NEXT_PUBLIC_API_URL=https://leadvirt.com/api
NEXT_PUBLIC_APP_URL=https://leadvirt.com
NEXT_PUBLIC_WEB_URL=https://leadvirt.com
NEXT_PUBLIC_DEMO_MODE=false
NEXT_PUBLIC_TELEGRAM_LOGIN_BOT=LeadVirtAi_bot

PORT=4001
CORS_ORIGINS=https://leadvirt.com,https://www.leadvirt.com
LOG_LEVEL=info

POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://leadvirt:change-me@postgres:5432/leadvirt?schema=public
# Use rediss:// for TLS; omitted ports default to 6379 and explicit provider ports are preserved.
REDIS_URL=redis://redis:6379

AUTH_MODE=local
AUTH_COOKIE_SECURE=true
AUTH_CREDENTIALS_ENABLED=false
AUTH_RATE_LIMIT_DISABLED=false
AUTH_EMAIL_OTP_ENABLED=true
AUTH_EMAIL_OTP_PEPPER=change-me-use-at-least-32-random-characters
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me
AUTH_2FA_ENCRYPTION_KEY=change-me
ENCRYPTION_KEY=change-me
INTEGRATION_CREDENTIALS_ENCRYPTION_KEY=change-me
CUSTOMER_IDENTITY_HMAC_KEY=change-me

TELEGRAM_BOT_API_BASE_URL=https://147-90-14-240.sslip.io:8443/telegram
TELEGRAM_WEBHOOK_BASE_URL=https://147-90-14-240.sslip.io:8443/telegram-webhook

AI_PROVIDER=openai
AI_DEFAULT_MODEL=gpt-5.5
AI_REASONING_EFFORT=low
AI_VERBOSITY=low
AI_REPLY_MODE=queue
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_ENABLE_REAL_PROVIDER=true
AI_TENANT_DAILY_TOKEN_BUDGET=0
AI_TENANT_MONTHLY_TOKEN_BUDGET=0

RAG_RETRIEVAL_MODE=qdrant
RAG_QDRANT_ENABLED=true
