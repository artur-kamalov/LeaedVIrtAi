{
  "name": "@leadvirt/business-import",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "qa:csv": "tsx src/csv-services.smoke.ts && tsx src/service-diff.smoke.ts",
