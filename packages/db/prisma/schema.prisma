model BusinessOfferingSourceBinding {
  id                      String   @id @default(cuid())
  tenantId                String
  sourceId                String
  offeringId              String
  externalKey             String
  normalizedCandidateKey  String?
  firstSeenImportId       String
  lastSeenImportId        String
  lastSeenSourceValueHash String
  active                  Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  source          BusinessImportSource @relation(fields: [tenantId, sourceId], references: [tenantId, id], onDelete: Restrict, onUpdate: NoAction)
  offering        BusinessOffering     @relation(fields: [tenantId, offeringId], references: [tenantId, id], onDelete: Restrict, onUpdate: NoAction)
  firstSeenImport BusinessImport       @relation("BusinessOfferingBindingFirstImport", fields: [tenantId, sourceId, firstSeenImportId], references: [tenantId, sourceId, id], onDelete: Restrict, onUpdate: NoAction)
  lastSeenImport  BusinessImport       @relation("BusinessOfferingBindingLastImport", fields: [tenantId, sourceId, lastSeenImportId], references: [tenantId, sourceId, id], onDelete: Restrict, onUpdate: NoAction)

  @@unique([tenantId, id])
  @@unique([tenantId, sourceId, externalKey])
  @@index([tenantId, offeringId])
  @@index([tenantId, sourceId, normalizedCandidateKey])
  @@index([tenantId, sourceId, active])
}

model BusinessImportApplication {
  id                           String                         @id @default(cuid())
  tenantId                     String
  sourceId                     String
  importId                     String
  kind                         BusinessImportApplicationKind  @default(APPLY)
  state                        BusinessImportApplicationState @default(COMMITTED)
  revertOfApplicationId        String?
  previewManifestHash          String
  previewObjectLedgerId        String
  previewObjectKind            BusinessImportObjectKind       @default(APPLICATION_PREVIEW)
  previewObjectKey             String
  previewEncryptionKeyRef      String
  candidateManifestHash        String
  idempotencyKeyHash           String
  idempotencyRequestHash       String
  baseInformationRevision      Int
  baseInformationHash          String
  baseBusinessRevisionId       String?
  resultingInformationRevision Int
  resultingInformationHash     String
  businessRevisionId           String
  affectedResourceVersions     Json
  projectionOutboxDedupeKey    String
  projectionOutboxId           String?
  projectionOutboxPrunedAt     DateTime?
  projectionReceiptHash        String?
  publicationId                String?
  createdByUserId              String
  committedAt                  DateTime                       @default(now())
  projectedAt                  DateTime?
  revertedAt                   DateTime?
  supersededAt                 DateTime?
  createdAt                    DateTime                       @default(now())
  updatedAt                    DateTime                       @updatedAt

  tenant               Tenant                                @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  import               BusinessImport                        @relation(fields: [tenantId, sourceId, importId], references: [tenantId, sourceId, id], onDelete: Restrict, onUpdate: NoAction)
  baseBusinessRevision BusinessInformationRevision?          @relation("BusinessImportApplicationBaseRevision", fields: [tenantId, baseBusinessRevisionId, baseInformationRevision, baseInformationHash], references: [tenantId, id, revision, canonicalHash], onDelete: Restrict, onUpdate: NoAction)
  businessRevision     BusinessInformationRevision           @relation("BusinessImportApplicationResultRevision", fields: [tenantId, businessRevisionId, resultingInformationRevision, resultingInformationHash], references: [tenantId, id, revision, canonicalHash], onDelete: Restrict, onUpdate: NoAction)
  previewObjectLedger  BusinessImportObjectLedger            @relation("BusinessImportApplicationPreviewLedger", fields: [tenantId, previewObjectLedgerId, previewObjectKind, previewObjectKey, previewEncryptionKeyRef], references: [tenantId, id, objectKind, objectStorageKey, encryptionKeyRef], onDelete: Restrict, onUpdate: NoAction)
  projectionOutbox     RuntimeOutbox?                        @relation("BusinessImportProjectionOutbox", fields: [projectionOutboxId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  actorMembership      Membership                            @relation("BusinessImportApplicationActor", fields: [tenantId, createdByUserId], references: [tenantId, userId], onDelete: Restrict, onUpdate: NoAction)
  publication          KnowledgePublication?                 @relation(fields: [tenantId, publicationId], references: [tenantId, id], onDelete: Restrict, onUpdate: NoAction)
  revertOf             BusinessImportApplication?            @relation("BusinessImportApplicationRevert", fields: [tenantId, revertOfApplicationId], references: [tenantId, id], onDelete: Restrict, onUpdate: NoAction)
  reverts              BusinessImportApplication[]           @relation("BusinessImportApplicationRevert")
  candidateItems       BusinessImportApplicationCandidate[]
  projectionReceipt    BusinessInformationProjectionReceipt?
  attributions         BusinessInformationAttribution[]

  @@unique([tenantId, id])
  @@unique([tenantId, importId, id])
  @@unique([tenantId, sourceId, importId, id], map: "BusinessImportApplication_source_context_key")
  @@unique([tenantId, sourceId, importId, id, businessRevisionId, resultingInformationRevision, resultingInformationHash], map: "BusinessImportApplication_revision_context_key")
  @@unique([tenantId, sourceId, importId, id, businessRevisionId, resultingInformationRevision, resultingInformationHash, projectionOutboxDedupeKey], map: "BusinessImportApplication_projection_context_key")
  @@unique([tenantId, businessRevisionId])
  @@unique([tenantId, idempotencyKeyHash])
  @@unique([tenantId, projectionOutboxDedupeKey])
  @@index([tenantId, importId, state])
  @@index([tenantId, resultingInformationRevision])
  @@index([tenantId, publicationId])
}

model BusinessImportApplicationCandidate {
  tenantId           String
  sourceId           String
  importId           String
  applicationId      String
  candidateId        String
  candidateVersion   Int
  candidateValueHash String
  action             BusinessImportCandidateAction
  targetCategory     BusinessImportTargetCategory
  risk               BusinessImportRiskLevel
  requiresApproval   Boolean
  requiredPermission String
  approvalGrantId    String?
  appliedAt          DateTime                      @default(now())

  tenant            Tenant                           @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  application       BusinessImportApplication        @relation(fields: [tenantId, sourceId, importId, applicationId], references: [tenantId, sourceId, importId, id], onDelete: Cascade, onUpdate: NoAction)
  candidate         BusinessImportCandidate          @relation(fields: [tenantId, sourceId, importId, candidateId], references: [tenantId, sourceId, importId, id], onDelete: Restrict, onUpdate: NoAction, map: "BusinessImportApplicationCandidate_candidate_fkey")
  candidateRevision BusinessImportCandidateRevision  @relation(fields: [tenantId, sourceId, importId, candidateId, candidateVersion, candidateValueHash, action, targetCategory, risk, requiresApproval, requiredPermission], references: [tenantId, sourceId, importId, candidateId, version, normalizedValueHash, action, targetCategory, risk, requiresApproval, requiredPermission], onDelete: Restrict, onUpdate: NoAction, map: "BusinessImportApplicationCandidate_revision_fkey")
  approvalGrant     BusinessImportApprovalGrant?     @relation(fields: [tenantId, sourceId, importId, candidateId, approvalGrantId, candidateVersion, candidateValueHash, requiredPermission], references: [tenantId, sourceId, importId, candidateId, id, candidateVersion, candidateValueHash, requiredPermission], onDelete: Restrict, onUpdate: NoAction, map: "BusinessImportApplicationCandidate_approval_grant_fkey")
  attributions      BusinessInformationAttribution[]

  @@id([tenantId, applicationId, candidateId])
  @@unique([tenantId, sourceId, importId, applicationId, candidateId, candidateVersion, candidateValueHash], map: "BusinessImportApplicationCandidate_attribution_key")
  @@index([tenantId, importId, candidateId])
  @@index([tenantId, approvalGrantId])
}

model BusinessInformationProjectionReceipt {
  id                         String    @id @default(cuid())
  tenantId                   String
  sourceId                   String?
  importId                   String?
  applicationId              String?   @unique
  businessRevisionId         String
  businessRevision           Int
  businessRevisionHash       String
  knowledgeTargetKey         String
  knowledgeDraftGeneration   Int
  knowledgeDraftManifestHash String
  runtimeOutboxId            String?
  runtimeOutboxDedupeKey     String
  runtimeOutboxPrunedAt      DateTime?
  receiptHash                String
  projectedAt                DateTime  @default(now())
  createdAt                  DateTime  @default(now())

  tenant              Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  import              BusinessImport?             @relation(fields: [tenantId, sourceId, importId], references: [tenantId, sourceId, id], onDelete: Restrict, onUpdate: NoAction, map: "BusinessInformationProjectionReceipt_import_fkey")
  application         BusinessImportApplication?  @relation(fields: [tenantId, sourceId, importId, applicationId, businessRevisionId, businessRevision, businessRevisionHash, runtimeOutboxDedupeKey], references: [tenantId, sourceId, importId, id, businessRevisionId, resultingInformationRevision, resultingInformationHash, projectionOutboxDedupeKey], onDelete: Restrict, onUpdate: NoAction, map: "BusinessInformationProjectionReceipt_application_fkey")
  informationRevision BusinessInformationRevision @relation(fields: [tenantId, businessRevisionId, businessRevision, businessRevisionHash], references: [tenantId, id, revision, canonicalHash], onDelete: Restrict, onUpdate: NoAction)
  runtimeOutbox       RuntimeOutbox?              @relation("BusinessInformationProjectionOutbox", fields: [runtimeOutboxId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  currentForState     BusinessInformationState?   @relation("BusinessInformationStateProjectionReceipt")

  @@unique([tenantId, id])
  @@unique([tenantId, id, businessRevisionId, businessRevision, businessRevisionHash, receiptHash], map: "BusinessInformationProjectionReceipt_exact_key")
  @@unique([tenantId, applicationId])
  @@unique([tenantId, sourceId, importId, applicationId, businessRevisionId, businessRevision, businessRevisionHash, runtimeOutboxDedupeKey], map: "BusinessInformationProjectionReceipt_application_key")
  @@unique([tenantId, runtimeOutboxDedupeKey])
  @@index([tenantId, businessRevision, projectedAt])
}

model BusinessInformationAttribution {
  id                   String                          @id @default(cuid())
  tenantId             String
  resourceType         BusinessInformationResourceType
  resourceKey          String
  identityId           String?
  offeringId           String?
  offeringPriceId      String?
  offeringDurationId   String?
  fieldPath            String
  currentValueHash     String
  sourceValueHash      String?
  authority            BusinessInformationAuthority
  confidence           BusinessImportConfidenceBand?
  sourceId             String?
  importId             String?
  candidateId          String?
  candidateVersion     Int?
  candidateValueHash   String?
  evidenceId           String?
  artifactId           String?
  artifactSha256       String?
  importGeneration     Int?
  parsedRevisionId     String?
  parsedManifestHash   String?
  applicationId        String?
  businessRevisionId   String
  businessRevision     Int
  businessRevisionHash String
  parserVersion        String?
  ocrVersion           String?
  mapperVersion        String?
  schemaVersion        String?
  modelVersion         String?
  promptVersion        String?
  approvedByUserId     String?
  approvedAt           DateTime?
  attributedAt         DateTime                        @default(now())
  supersededAt         DateTime?
  createdAt            DateTime                        @default(now())

  tenant               Tenant                              @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  identity             BusinessIdentity?                   @relation(fields: [tenantId, identityId], references: [tenantId, id], onDelete: Restrict, onUpdate: NoAction)
  offering             BusinessOffering?                   @relation(fields: [tenantId, offeringId], references: [tenantId, id], onDelete: Restrict, onUpdate: NoAction)
  offeringPrice        BusinessOfferingPrice?              @relation(fields: [tenantId, offeringPriceId], references: [tenantId, id], onDelete: Restrict, onUpdate: NoAction)
  offeringDuration     BusinessOfferingDuration?           @relation(fields: [tenantId, offeringDurationId], references: [tenantId, id], onDelete: Restrict, onUpdate: NoAction)
  source               BusinessImportSource?               @relation(fields: [tenantId, sourceId], references: [tenantId, id], onDelete: Restrict, onUpdate: NoAction)
  import               BusinessImport?                     @relation(fields: [tenantId, importId], references: [tenantId, id], onDelete: Restrict, onUpdate: NoAction)
  candidate            BusinessImportCandidate?            @relation(fields: [tenantId, sourceId, importId, candidateId], references: [tenantId, sourceId, importId, id], onDelete: Restrict, onUpdate: NoAction, map: "BusinessInformationAttribution_candidate_fkey")
  candidateRevision    BusinessImportCandidateRevision?    @relation(fields: [tenantId, sourceId, importId, candidateId, candidateVersion, candidateValueHash, parsedRevisionId, importGeneration, artifactId, artifactSha256, parsedManifestHash], references: [tenantId, sourceId, importId, candidateId, version, normalizedValueHash, parsedRevisionId, importGeneration, artifactId, artifactSha256, parsedManifestHash], onDelete: Restrict, onUpdate: NoAction, map: "BusinessInformationAttribution_candidate_revision_fkey")
  evidence             BusinessImportCandidateEvidence?    @relation(fields: [tenantId, sourceId, importId, candidateId, candidateVersion, candidateValueHash, artifactId, artifactSha256, importGeneration, parsedRevisionId, parsedManifestHash, sourceValueHash, evidenceId], references: [tenantId, sourceId, importId, candidateId, candidateVersion, candidateValueHash, artifactId, artifactSha256, importGeneration, parsedRevisionId, parsedManifestHash, sourceValueHash, id], onDelete: Restrict, onUpdate: NoAction, map: "BusinessInformationAttribution_evidence_fkey")
  artifact             BusinessImportArtifact?             @relation(fields: [tenantId, sourceId, artifactId, artifactSha256], references: [tenantId, sourceId, id, sha256], onDelete: Restrict, onUpdate: NoAction)
  application          BusinessImportApplication?          @relation(fields: [tenantId, sourceId, importId, applicationId, businessRevisionId, businessRevision, businessRevisionHash], references: [tenantId, sourceId, importId, id, businessRevisionId, resultingInformationRevision, resultingInformationHash], onDelete: Restrict, onUpdate: NoAction, map: "BusinessInformationAttribution_application_fkey")
  applicationCandidate BusinessImportApplicationCandidate? @relation(fields: [tenantId, sourceId, importId, applicationId, candidateId, candidateVersion, candidateValueHash], references: [tenantId, sourceId, importId, applicationId, candidateId, candidateVersion, candidateValueHash], onDelete: Restrict, onUpdate: NoAction, map: "BusinessInformationAttribution_application_candidate_fkey")
  informationRevision  BusinessInformationRevision         @relation(fields: [tenantId, businessRevisionId, businessRevision, businessRevisionHash], references: [tenantId, id, revision, canonicalHash], onDelete: Restrict, onUpdate: NoAction)
  approverMembership   Membership?                         @relation("BusinessInformationAttributionApprover", fields: [tenantId, approvedByUserId], references: [tenantId, userId], onDelete: Restrict, onUpdate: NoAction)

  @@unique([tenantId, id])
  @@index([tenantId, resourceType, resourceKey, fieldPath, supersededAt])
  @@index([tenantId, sourceId, importId])
  @@index([tenantId, candidateId])
  @@index([tenantId, businessRevisionId])
  @@index([tenantId, artifactId])
}

model BusinessImportQuotaReservation {
  id                  String                    @id @default(cuid())
  tenantId            String
  importId            String
  status              BusinessImportQuotaStatus @default(RESERVED)
  rawBytes            BigInt                    @default(0)
  expandedBytes       BigInt                    @default(0)
  sheetCount          Int                       @default(0)
  rowCount            Int                       @default(0)
  columnCount         Int                       @default(0)
  cellCount           BigInt                    @default(0)
  pdfPageCount        Int                       @default(0)
  ocrPageCount        Int                       @default(0)
  ocrPixels           BigInt                    @default(0)
  processorSeconds    Int                       @default(0)
  extractedCharacters Int                       @default(0)
  candidateCount      Int                       @default(0)
  modelTokens         BigInt                    @default(0)
  retainedBytes       BigInt                    @default(0)
  expiresAt           DateTime
  consumedAt          DateTime?
  releasedAt          DateTime?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  import BusinessImport @relation(fields: [tenantId, importId], references: [tenantId, id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenantId, id])
  @@unique([tenantId, importId])
  @@index([status, expiresAt])
  @@index([tenantId, status, createdAt])
}
