  guidanceRule     KnowledgeV2GuidanceRule?        @relation(fields: [tenantId, guidanceRuleId], references: [tenantId, id], onDelete: Restrict, onUpdate: NoAction)
  conflict         KnowledgeV2Conflict?            @relation(fields: [tenantId, conflictId, corpusKind], references: [tenantId, id, corpusKind], onDelete: Restrict, onUpdate: NoAction)
