  businessImportCandidateApprovals      BusinessImportCandidateApproval[]
  businessImportApprovalGrants          BusinessImportApprovalGrant[]
  businessImportCandidateEvidence       BusinessImportCandidateEvidence[]
  businessImportParsedRevisions         BusinessImportParsedRevision[]
  businessImportApplications            BusinessImportApplication[]
  businessImportApplicationItems        BusinessImportApplicationCandidate[]
  businessOfferingSourceBindings        BusinessOfferingSourceBinding[]
  businessInformationAttributions       BusinessInformationAttribution[]
  businessInformationProjectionReceipts BusinessInformationProjectionReceipt[]
  businessImportObjectLedger            BusinessImportObjectLedger[]
  businessImportQuotaReservations       BusinessImportQuotaReservation[]

  @@index([status])
