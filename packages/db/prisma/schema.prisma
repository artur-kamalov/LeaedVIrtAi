  createdByUserId     String?
  archivedByUserId    String?
  archivedAt          DateTime?
  etag                Int                       @default(1)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  tenant         Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  currentVersion KnowledgeV2TestCaseVersion?  @relation("KnowledgeV2CurrentTestCaseVersion", fields: [tenantId, id, currentVersionId], references: [tenantId, testCaseId, id], onDelete: NoAction, onUpdate: NoAction)
