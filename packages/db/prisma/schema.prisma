model TenantOperationalAuthorizationState {
  tenantId             String   @id
  permissionGeneration Int      @default(1)
  updatedAt            DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model User {
  id                       String    @id @default(cuid())
  externalAuthId           String?   @unique
  email                    String    @unique
  phone                    String?   @unique
  passwordHash             String?
  passwordChangeRequired   Boolean   @default(false)
  twoFactorEnabled         Boolean   @default(false)
  twoFactorSecretEncrypted String?
  twoFactorRecoveryCodes   Json?
  twoFactorConfirmedAt     DateTime?
  name                     String?
  avatarUrl                String?
  locale                   String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  deletedAt                DateTime?

  memberships         Membership[]
  authSessions        AuthSession[]
  passwordResetTokens AuthPasswordResetToken[]
  assignedLeads       Lead[]                   @relation("AssignedLeads")
  messages            Message[]                @relation("UserMessages")
  tasks               Task[]                   @relation("AssignedTasks")
  auditLogs           AuditLog[]               @relation("ActorAuditLogs")
}

model AuthSession {
  id         String    @id @default(cuid())
  userId     String
  tenantId   String
  tokenHash  String    @unique
  authMode   String    @default("credentials")
  expiresAt  DateTime
  revokedAt  DateTime?
  lastUsedAt DateTime?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([tenantId, expiresAt])
}

model AuthEmailOtpChallenge {
  id                String    @id
  email             String
  codeHash          String
  deliveryMode      String
  locale            String
  attempts          Int       @default(0)
  providerMessageId String?
  expiresAt         DateTime
  consumedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([email, createdAt])
  @@index([expiresAt])
}

model AuthPasswordResetToken {
  id           String    @id @default(cuid())
  userId       String
  tokenHash    String    @unique
  deliveryMode String
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model Membership {
  id        String         @id @default(cuid())
  tenantId  String
  userId    String
  role      MembershipRole @default(AGENT)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  tenant                                  Tenant                            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
