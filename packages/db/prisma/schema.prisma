model Tenant {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  status       TenantStatus @default(TRIALING)
  businessType String?
  timezone     String       @default("UTC")
  settings     Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  memberships                       Membership[]
  channels                          Channel[]
  webhookEvents                     WebhookEvent[]
  leads                             Lead[]
  leadEvents                        LeadEvent[]
  conversations                     Conversation[]
  messages                          Message[]
  messageAttachments                MessageAttachment[]
  workflows                         Workflow[]
  workflowRuns                      WorkflowRun[]
  integrations                      IntegrationAccount[]
  integrationSyncLogs               IntegrationSyncLog[]
  aiUsageLogs                       AiUsageLog[]
  auditLogs                         AuditLog[]
  subscriptions                     Subscription[]
  usageCounters                     UsageCounter[]
  tasks                             Task[]
  bookings                          Booking[]
  orders                            Order[]
  apiKeys                           ApiKey[]
  authSessions                      AuthSession[]
  onboardingState                   OnboardingState?
  knowledgeSources                  BusinessKnowledgeSource[]
  knowledgeChunks                   BusinessKnowledgeChunk[]
  knowledgeRevisions                KnowledgeRevision[]
  knowledgeRevisionChunks           KnowledgeRevisionChunk[]
  knowledgeIndexSnapshots           KnowledgeIndexSnapshot[]
  knowledgePublications             KnowledgePublication[]
  activeKnowledgePublications       ActiveKnowledgePublication[]
  knowledgeJobs                     KnowledgeJob[]
  knowledgeOutbox                   KnowledgeOutbox[]
  knowledgeInbox                    KnowledgeInbox[]
  knowledgeV2Settings               KnowledgeV2Settings?
  knowledgeV2Entities               KnowledgeV2Entity[]
  knowledgeV2Facts                  KnowledgeV2Fact[]
  knowledgeV2FactVersions           KnowledgeV2FactVersion[]
  knowledgeV2GuidanceRules          KnowledgeV2GuidanceRule[]
  knowledgeV2GuidanceVersions       KnowledgeV2GuidanceRuleVersion[]
  knowledgeV2Evidence               KnowledgeV2Evidence[]
  knowledgeV2Idempotency            KnowledgeV2IdempotencyRecord[]
  knowledgeV2Validations            KnowledgeV2PublicationValidation[]
  knowledgeV2Capabilities           KnowledgeV2Capability[]
  knowledgeV2RequirementDefinitions KnowledgeV2RequirementDefinition[]
  knowledgeV2RequirementEvaluations KnowledgeV2RequirementEvaluation[]
  knowledgePublicationCapabilities  KnowledgePublicationCapability[]
  knowledgeV2Sources                KnowledgeV2Source[]
  knowledgeV2FileUploadIntents      KnowledgeV2FileUploadIntent[]
  knowledgeV2Artifacts              KnowledgeV2Artifact[]
  knowledgeV2Documents              KnowledgeV2Document[]
  knowledgeV2Revisions              KnowledgeV2DocumentRevision[]
  knowledgeV2Elements               KnowledgeV2Element[]
  knowledgeV2Chunks                 KnowledgeV2Chunk[]
  knowledgeV2EmbeddingCaches        KnowledgeV2EmbeddingCache[]
  knowledgeV2LegacyMigrations       KnowledgeV2LegacyMigration[]
  knowledgeCorpusSelector           KnowledgeCorpusSelector?
  knowledgeV2DeletionLedger         KnowledgeV2DeletionLedger[]
  knowledgeV2EvidenceRefs           KnowledgeV2EvidenceReference[]
  knowledgeV2Conflicts              KnowledgeV2Conflict[]
  knowledgeV2ConflictCandidates     KnowledgeV2ConflictCandidate[]
  knowledgeV2ConflictEvidence       KnowledgeV2ConflictCandidateEvidence[]
  knowledgeV2ReviewItems            KnowledgeV2ReviewItem[]
  knowledgeV2ReviewEvidence         KnowledgeV2ReviewItemEvidence[]
  knowledgeV2TestCases              KnowledgeV2TestCase[]
  knowledgeV2TestCaseVersions       KnowledgeV2TestCaseVersion[]
  knowledgeV2TestExpectations       KnowledgeV2TestExpectation[]
  knowledgeV2EvaluationRuns         KnowledgeV2EvaluationRun[]
  knowledgeV2EvaluationResults      KnowledgeV2EvaluationResult[]
  knowledgeV2EvaluationMetrics      KnowledgeV2EvaluationMetric[]
  knowledgeV2EvaluationEvidence     KnowledgeV2EvaluationResultEvidence[]
  knowledgeV2Feedback               KnowledgeV2Feedback[]
  knowledgeV2FeedbackEvidence       KnowledgeV2FeedbackEvidence[]
  knowledgeV2RetrievalTraces        KnowledgeV2RetrievalTrace[]
  knowledgeV2RetrievalCandidates    KnowledgeV2RetrievalCandidate[]
  knowledgeV2Citations              KnowledgeV2Citation[]
  aiReplyRuns                       AiReplyRun[]
  externalOperations                ExternalOperation[]
  channelDeliveryOperations         ChannelDeliveryOperation[]
  runtimeOutbox                     RuntimeOutbox[]
  runtimeInbox                      RuntimeInbox[]
  operationalAuthorizationState     TenantOperationalAuthorizationState?
  knowledgeV2LiveToolExecutions     KnowledgeV2LiveToolExecution[]
  authenticatedCustomerIdentities   AuthenticatedCustomerIdentity[]

  @@index([status])
}

model TenantOperationalAuthorizationState {
  tenantId             String   @id
  permissionGeneration Int      @default(1)
  updatedAt            DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model User {
  id                       String    @id @default(cuid())
  externalAuthId           String?   @unique
  email                    String    @unique
  phone                    String?   @unique
  passwordHash             String?
  passwordChangeRequired   Boolean   @default(false)
  twoFactorEnabled         Boolean   @default(false)
  twoFactorSecretEncrypted String?
  twoFactorRecoveryCodes   Json?
  twoFactorConfirmedAt     DateTime?
  name                     String?
  avatarUrl                String?
  locale                   String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  deletedAt                DateTime?

  memberships         Membership[]
  authSessions        AuthSession[]
  passwordResetTokens AuthPasswordResetToken[]
  assignedLeads       Lead[]                   @relation("AssignedLeads")
  messages            Message[]                @relation("UserMessages")
  tasks               Task[]                   @relation("AssignedTasks")
  auditLogs           AuditLog[]               @relation("ActorAuditLogs")
}

model AuthSession {
  id         String    @id @default(cuid())
  userId     String
  tenantId   String
  tokenHash  String    @unique
  authMode   String    @default("credentials")
  expiresAt  DateTime
  revokedAt  DateTime?
  lastUsedAt DateTime?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([tenantId, expiresAt])
}

model AuthEmailOtpChallenge {
  id                String    @id
  email             String
  codeHash          String
  deliveryMode      String
  locale            String
  attempts          Int       @default(0)
  providerMessageId String?
  expiresAt         DateTime
  consumedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([email, createdAt])
  @@index([expiresAt])
}

model AuthPasswordResetToken {
  id           String    @id @default(cuid())
  userId       String
  tokenHash    String    @unique
  deliveryMode String
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model Membership {
  id        String         @id @default(cuid())
  tenantId  String
  userId    String
  role      MembershipRole @default(AGENT)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  tenant                           Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                             User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedKnowledgeConflicts       KnowledgeV2Conflict[]         @relation("KnowledgeV2ConflictAssignee")
  resolvedKnowledgeConflicts       KnowledgeV2Conflict[]         @relation("KnowledgeV2ConflictResolver")
  createdKnowledgeReviewItems      KnowledgeV2ReviewItem[]       @relation("KnowledgeV2ReviewItemCreator")
  assignedKnowledgeReviewItems     KnowledgeV2ReviewItem[]       @relation("KnowledgeV2ReviewItemAssignee")
  resolvedKnowledgeReviewItems     KnowledgeV2ReviewItem[]       @relation("KnowledgeV2ReviewItemResolver")
  requestedKnowledgeV2Migrations   KnowledgeV2LegacyMigration[]  @relation("KnowledgeV2LegacyMigrationRequester")
  selectedKnowledgeCorpus          KnowledgeCorpusSelector[]     @relation("KnowledgeCorpusSelectorActor")
  createdKnowledgeTestCases        KnowledgeV2TestCase[]         @relation("KnowledgeV2TestCaseCreator")
  archivedKnowledgeTestCases       KnowledgeV2TestCase[]         @relation("KnowledgeV2TestCaseArchiver")
  createdKnowledgeTestCaseVersions KnowledgeV2TestCaseVersion[]  @relation("KnowledgeV2TestCaseVersionCreator")
  requestedKnowledgeEvaluationRuns KnowledgeV2EvaluationRun[]    @relation("KnowledgeV2EvaluationRunRequester")
  authoredKnowledgeFeedback        KnowledgeV2Feedback[]         @relation("KnowledgeV2FeedbackActor")
  assignedKnowledgeFeedback        KnowledgeV2Feedback[]         @relation("KnowledgeV2FeedbackAssignee")
  resolvedKnowledgeFeedback        KnowledgeV2Feedback[]         @relation("KnowledgeV2FeedbackResolver")
  knowledgeV2FileUploadIntents     KnowledgeV2FileUploadIntent[]

  @@unique([tenantId, userId])
  @@index([tenantId, role])
}

model BillingPlan {
  id              String   @id @default(cuid())
  code            PlanCode @unique
  name            String
  priceMonthlyRub Int?
  aiConversations Int?
  channelsLimit   Int?
  usersLimit      Int?
  scenariosLimit  Int?
  features        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id          String    @id @default(cuid())
  tenantId    String
  planId      String
  status      String    @default("ACTIVE")
  periodStart DateTime  @default(now())
  periodEnd   DateTime
  trialEndsAt DateTime?
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   BillingPlan @relation(fields: [planId], references: [id])

  @@index([tenantId, status])
  @@index([planId])
}

model UsageCounter {
  id               String   @id @default(cuid())
  tenantId         String
  periodStart      DateTime
  periodEnd        DateTime
  aiConversations  Int      @default(0)
  messagesSent     Int      @default(0)
  messagesReceived Int      @default(0)
  leadsCreated     Int      @default(0)
  bookingsCreated  Int      @default(0)
  ordersCreated    Int      @default(0)
  crmSyncs         Int      @default(0)
  workflowRuns     Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, periodStart, periodEnd])
  @@index([tenantId, periodEnd])
}

model Channel {
  id                                 String        @id @default(cuid())
  tenantId                           String
  type                               ChannelType
  status                             ChannelStatus @default(PENDING)
  name                               String
  externalId                         String?
  publicKey                          String?       @unique
  settings                           Json?
  encryptedCredentials               String?
  lastHealthAt                       DateTime?
  automaticRepliesEnabled            Boolean       @default(false)
  automaticRepliesGeneration         Int           @default(1)
  automaticRepliesPublicationId      String?
  automaticRepliesPublicationEtag    Int?
  automaticRepliesChannelFingerprint String?
  automaticRepliesCapabilitySetHash  String?
  automaticRepliesOperationalBindingHash String?
  automaticRepliesOperationalPermissionGeneration Int?
  automaticRepliesActivatedAt        DateTime?
  automaticRepliesActivatedByUserId  String?
  createdAt                          DateTime      @default(now())
  updatedAt                          DateTime      @updatedAt
  deletedAt                          DateTime?

  tenant                      Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
