  queryHashVersion String
  keyCheck         String
  createdAt        DateTime @default(now())
}

model KnowledgeV2TestCase {
  id                  String                    @id @default(cuid())
  tenantId            String
  corpusKind          KnowledgeCorpusKind       @default(STRUCTURED_V2)
  caseKey             String
  safeLabel           String
  origin              KnowledgeV2TestCaseOrigin
  status              KnowledgeV2TestCaseStatus @default(DRAFT)
  riskLevel           KnowledgeV2RiskLevel      @default(LOW)
  critical            Boolean                   @default(false)
  currentVersionId    String?
  latestVersionNumber Int                       @default(0)
  createdByUserId     String?
  archivedByUserId    String?
  archivedAt          DateTime?
  etag                Int                       @default(1)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  tenant         Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  currentVersion KnowledgeV2TestCaseVersion?  @relation("KnowledgeV2CurrentTestCaseVersion", fields: [tenantId, id, currentVersionId], references: [tenantId, testCaseId, id], onDelete: NoAction, onUpdate: NoAction)
  versions       KnowledgeV2TestCaseVersion[] @relation("KnowledgeV2TestCaseVersions")
  createdBy      Membership?                  @relation("KnowledgeV2TestCaseCreator", fields: [tenantId, createdByUserId], references: [tenantId, userId], onDelete: NoAction, onUpdate: NoAction)
  archivedBy     Membership?                  @relation("KnowledgeV2TestCaseArchiver", fields: [tenantId, archivedByUserId], references: [tenantId, userId], onDelete: NoAction, onUpdate: NoAction)

  @@unique([tenantId, caseKey])
  @@unique([tenantId, id])
  @@unique([tenantId, id, corpusKind])
  @@unique([tenantId, id, currentVersionId])
  @@index([tenantId, status, riskLevel, updatedAt])
  @@index([tenantId, origin, status])
}

model KnowledgeV2TestCaseVersion {
  id                  String                      @id @default(cuid())
  tenantId            String
  corpusKind          KnowledgeCorpusKind         @default(STRUCTURED_V2)
  testCaseId          String
  versionNumber       Int
  queryHash           String
  queryHashKeyId      String?
  queryHashVersion    String?
  restrictedInputRef  String
  expectedBehavior    KnowledgeV2ExpectedBehavior
  locale              String
  channelType         ChannelType
  audience            KnowledgeV2Audience
  scope               Json?
  sliceKeys           String[]                    @default([])
  datasetVersion      String
  riskLevel           KnowledgeV2RiskLevel        @default(LOW)
  supersedesVersionId String?
  immutableHash       String
  createdByUserId     String?
  createdAt           DateTime                    @default(now())

  tenant             Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  testCase           KnowledgeV2TestCase           @relation("KnowledgeV2TestCaseVersions", fields: [tenantId, testCaseId, corpusKind], references: [tenantId, id, corpusKind], onDelete: Restrict, onUpdate: NoAction)
  currentForTestCase KnowledgeV2TestCase?          @relation("KnowledgeV2CurrentTestCaseVersion")
  supersedes         KnowledgeV2TestCaseVersion?   @relation("KnowledgeV2TestCaseVersionSupersession", fields: [tenantId, testCaseId, supersedesVersionId], references: [tenantId, testCaseId, id], onDelete: Restrict, onUpdate: NoAction)
  supersededBy       KnowledgeV2TestCaseVersion[]  @relation("KnowledgeV2TestCaseVersionSupersession")
  createdBy          Membership?                   @relation("KnowledgeV2TestCaseVersionCreator", fields: [tenantId, createdByUserId], references: [tenantId, userId], onDelete: NoAction, onUpdate: NoAction)
  expectations       KnowledgeV2TestExpectation[]
  evaluationResults  KnowledgeV2EvaluationResult[]

  @@unique([testCaseId, versionNumber])
  @@unique([testCaseId, immutableHash])
  @@unique([tenantId, id])
  @@unique([tenantId, id, corpusKind])
  @@unique([tenantId, testCaseId, id])
  @@index([tenantId, testCaseId, createdAt])
  @@index([tenantId, datasetVersion])
  @@index([tenantId, locale, channelType, audience])
}

model KnowledgeV2TestExpectation {
  id                    String                         @id @default(cuid())
  tenantId              String
  corpusKind            KnowledgeCorpusKind            @default(STRUCTURED_V2)
  testCaseVersionId     String
  ordinal               Int
  kind                  KnowledgeV2TestExpectationKind
  factId                String?
  guidanceRuleId        String?
  evidenceReferenceId   String?
  semanticKey           String?
  expectedValueHash     String?
  restrictedExpectedRef String?
  createdAt             DateTime                       @default(now())

  tenant            Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  testCaseVersion   KnowledgeV2TestCaseVersion    @relation(fields: [tenantId, testCaseVersionId, corpusKind], references: [tenantId, id, corpusKind], onDelete: Restrict, onUpdate: NoAction)
  fact              KnowledgeV2Fact?              @relation(fields: [tenantId, factId], references: [tenantId, id], onDelete: Restrict, onUpdate: NoAction)
  guidanceRule      KnowledgeV2GuidanceRule?      @relation(fields: [tenantId, guidanceRuleId], references: [tenantId, id], onDelete: Restrict, onUpdate: NoAction)
  evidenceReference KnowledgeV2EvidenceReference? @relation(fields: [tenantId, evidenceReferenceId, corpusKind], references: [tenantId, id, corpusKind], onDelete: Restrict, onUpdate: NoAction)

  @@unique([tenantId, testCaseVersionId, ordinal])
  @@unique([tenantId, id])
  @@index([tenantId, factId])
  @@index([tenantId, guidanceRuleId])
  @@index([tenantId, evidenceReferenceId])
}

model KnowledgeV2EvaluationRun {
  id                           String                         @id @default(cuid())
  tenantId                     String
  corpusKind                   KnowledgeCorpusKind            @default(STRUCTURED_V2)
  runKey                       String
  runKind                      KnowledgeV2EvaluationRunKind
  status                       KnowledgeV2EvaluationRunStatus @default(QUEUED)
  snapshotKind                 KnowledgeV2SnapshotKind
  targetKey                    String                         @default("workspace-v2")
  publicationId                String?
  candidateId                  String?
  candidateVersion             Int?
  candidateManifestHash        String?
  datasetVersion               String
  testCaseSetHash              String
  configHash                   String
  restrictedConfigRef          String?
  queryHash                    String?
  queryHashKeyId               String?
  queryHashVersion             String?
  restrictedInputRef           String?
  parserVersion                String?
  normalizerVersion            String?
  chunkerVersion               String?
  embeddingVersion             String?
  sparseVersion                String?
  rerankerVersion              String?
  retrievalPolicyVersion       String
  retrievalProcessorPolicyHash String?
  modelProcessorPolicyHash     String?
  promptPolicyVersion          String
  graphVersion                 String
  provider                     String?
  generatorModel               String?
  judgeModel                   String?
  judgePromptVersion           String?
  codeCommit                   String
  environment                  String
  requestedByUserId            String?
  startedAt                    DateTime?
  completedAt                  DateTime?
  cancelledAt                  DateTime?
  createdAt                    DateTime                       @default(now())
  updatedAt                    DateTime                       @updatedAt

  tenant      Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  publication KnowledgePublication?         @relation(fields: [tenantId, publicationId, corpusKind], references: [tenantId, id, corpusKind], onDelete: Restrict, onUpdate: NoAction)
  requestedBy Membership?                   @relation("KnowledgeV2EvaluationRunRequester", fields: [tenantId, requestedByUserId], references: [tenantId, userId], onDelete: NoAction, onUpdate: NoAction)
  results     KnowledgeV2EvaluationResult[]
  feedback    KnowledgeV2Feedback[]
  traces      KnowledgeV2RetrievalTrace[]

  @@unique([tenantId, runKey])
  @@unique([tenantId, id])
  @@unique([tenantId, id, corpusKind])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, runKind, datasetVersion])
  @@index([tenantId, publicationId])
  @@index([tenantId, candidateId, candidateVersion])
}

model KnowledgeV2EvaluationResult {
  id                       String                            @id @default(cuid())
  tenantId                 String
  corpusKind               KnowledgeCorpusKind               @default(STRUCTURED_V2)
  resultKey                String
  evaluationRunId          String
  testCaseVersionId        String?
  repeatIndex              Int                               @default(0)
  status                   KnowledgeV2EvaluationResultStatus
  expectedBehavior         KnowledgeV2ExpectedBehavior?
  observedBehavior         KnowledgeV2ExpectedBehavior?
  gateOutcome              KnowledgeV2GateOutcome?
  provider                 String?
  generatorModel           String?
  promptPolicyVersion      String?
  modelProcessorPolicyHash String?
  providerOutputHash       String?
  gateInputHash            String?
  gateResultHash           String?
  responseHash             String?
  restrictedResultRef      String?
  restrictedResultHash     String?
  safeSummaryHash          String?
  metricManifestHash       String
  evidenceManifestHash     String
  errorCode                String?
  latencyMs                Int?
  inputTokens              Int?
  outputTokens             Int?
  costMicros               BigInt?
  createdAt                DateTime                          @default(now())

  tenant          Tenant                                @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  evaluationRun   KnowledgeV2EvaluationRun              @relation(fields: [tenantId, evaluationRunId, corpusKind], references: [tenantId, id, corpusKind], onDelete: Restrict, onUpdate: NoAction)
  testCaseVersion KnowledgeV2TestCaseVersion?           @relation(fields: [tenantId, testCaseVersionId, corpusKind], references: [tenantId, id, corpusKind], onDelete: Restrict, onUpdate: NoAction)
  metrics         KnowledgeV2EvaluationMetric[]
  evidenceLinks   KnowledgeV2EvaluationResultEvidence[]
  reviewItems     KnowledgeV2ReviewItem[]
  feedback        KnowledgeV2Feedback[]
  retrievalTraces KnowledgeV2RetrievalTrace[]

  @@unique([tenantId, resultKey])
  @@unique([tenantId, evaluationRunId, testCaseVersionId, repeatIndex])
  @@unique([tenantId, id])
  @@unique([tenantId, id, corpusKind])
  @@unique([tenantId, id, evaluationRunId, corpusKind])
  @@index([tenantId, evaluationRunId, status])
  @@index([tenantId, testCaseVersionId, status])
  @@index([tenantId, gateOutcome])
}

model KnowledgeV2EvaluationMetric {
  id                 String                            @id @default(cuid())
  tenantId           String
  corpusKind         KnowledgeCorpusKind               @default(STRUCTURED_V2)
  evaluationResultId String
  metricKey          String
  category           KnowledgeV2MetricCategory
  value              Float?
  numerator          Float?
  denominator        Float?
  unit               String?
  threshold          Float?
  comparator         KnowledgeV2MetricComparator?
  status             KnowledgeV2EvaluationResultStatus
  sliceKey           String?
  sampleCount        Int?
  confidenceLower    Float?
  confidenceUpper    Float?
  createdAt          DateTime                          @default(now())

  tenant           Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  evaluationResult KnowledgeV2EvaluationResult @relation(fields: [tenantId, evaluationResultId, corpusKind], references: [tenantId, id, corpusKind], onDelete: Restrict, onUpdate: NoAction)

  @@unique([tenantId, evaluationResultId, metricKey])
  @@unique([tenantId, id])
  @@index([tenantId, category, status])
  @@index([tenantId, metricKey, sliceKey])
}

model KnowledgeV2EvaluationResultEvidence {
  tenantId            String
  corpusKind          KnowledgeCorpusKind @default(STRUCTURED_V2)
  evaluationResultId  String
  evidenceReferenceId String
  ordinal             Int
  relevanceScore      Float?
  createdAt           DateTime            @default(now())

  tenant            Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  evaluationResult  KnowledgeV2EvaluationResult  @relation(fields: [tenantId, evaluationResultId, corpusKind], references: [tenantId, id, corpusKind], onDelete: Restrict, onUpdate: NoAction)
  evidenceReference KnowledgeV2EvidenceReference @relation(fields: [tenantId, evidenceReferenceId, corpusKind], references: [tenantId, id, corpusKind], onDelete: Restrict, onUpdate: NoAction)

  @@id([tenantId, evaluationResultId, evidenceReferenceId])
  @@unique([tenantId, evaluationResultId, ordinal])
  @@index([tenantId, evidenceReferenceId])
}

model KnowledgeV2Feedback {
  id                      String                           @id @default(cuid())
  tenantId                String
  corpusKind              KnowledgeCorpusKind              @default(STRUCTURED_V2)
  feedbackKey             String
  category                KnowledgeV2FeedbackCategory
  status                  KnowledgeV2FeedbackStatus        @default(OPEN)
  riskLevel               KnowledgeV2RiskLevel             @default(LOW)
  responseMessageId       String?
  evaluationRunId         String?
  evaluationResultId      String?
  publicationId           String?
  retrievalTraceId        String?
  actorUserId             String?
  noteHash                String?
  restrictedNoteRef       String?
  proposedAction          KnowledgeV2ReviewAction?
  correctionTargetType    KnowledgeV2CorrectionTargetType?
  sourceId                String?
  v2DocumentRevisionId    String?
  factId                  String?
  guidanceRuleId          String?
  assignedToUserId        String?
  assignedAt              DateTime?
  resolutionAction        KnowledgeV2ReviewAction?
  resolutionSummaryHash   String?
  restrictedResolutionRef String?
  resolvedByUserId        String?
  resolvedAt              DateTime?
  etag                    Int                              @default(1)
  createdAt               DateTime                         @default(now())
  updatedAt               DateTime                         @updatedAt

  tenant           Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  responseMessage  Message?                      @relation(fields: [tenantId, responseMessageId], references: [tenantId, id], onDelete: Restrict, onUpdate: NoAction)
  evaluationRun    KnowledgeV2EvaluationRun?     @relation(fields: [tenantId, evaluationRunId, corpusKind], references: [tenantId, id, corpusKind], onDelete: Restrict, onUpdate: NoAction)
  evaluationResult KnowledgeV2EvaluationResult?  @relation(fields: [tenantId, evaluationResultId, evaluationRunId, corpusKind], references: [tenantId, id, evaluationRunId, corpusKind], onDelete: Restrict, onUpdate: NoAction)
  publication      KnowledgePublication?         @relation(fields: [tenantId, publicationId, corpusKind], references: [tenantId, id, corpusKind], onDelete: Restrict, onUpdate: NoAction)
  retrievalTrace   KnowledgeV2RetrievalTrace?    @relation(fields: [tenantId, retrievalTraceId, corpusKind], references: [tenantId, id, corpusKind], onDelete: Restrict, onUpdate: NoAction)
  source           KnowledgeV2Source?            @relation(fields: [tenantId, sourceId], references: [tenantId, id], onDelete: Restrict, onUpdate: NoAction)
  documentRevision KnowledgeV2DocumentRevision?  @relation(fields: [tenantId, v2DocumentRevisionId], references: [tenantId, id], onDelete: Restrict, onUpdate: NoAction)
  fact             KnowledgeV2Fact?              @relation(fields: [tenantId, factId], references: [tenantId, id], onDelete: Restrict, onUpdate: NoAction)
  guidanceRule     KnowledgeV2GuidanceRule?      @relation(fields: [tenantId, guidanceRuleId], references: [tenantId, id], onDelete: Restrict, onUpdate: NoAction)
  actor            Membership?                   @relation("KnowledgeV2FeedbackActor", fields: [tenantId, actorUserId], references: [tenantId, userId], onDelete: NoAction, onUpdate: NoAction)
  assignee         Membership?                   @relation("KnowledgeV2FeedbackAssignee", fields: [tenantId, assignedToUserId], references: [tenantId, userId], onDelete: NoAction, onUpdate: NoAction)
  resolvedBy       Membership?                   @relation("KnowledgeV2FeedbackResolver", fields: [tenantId, resolvedByUserId], references: [tenantId, userId], onDelete: NoAction, onUpdate: NoAction)
  evidenceLinks    KnowledgeV2FeedbackEvidence[]
  reviewItems      KnowledgeV2ReviewItem[]

  @@unique([tenantId, feedbackKey])
  @@unique([tenantId, id])
  @@unique([tenantId, id, corpusKind])
  @@index([tenantId, status, category, createdAt])
  @@index([tenantId, assignedToUserId, status])
  @@index([tenantId, responseMessageId])
  @@index([tenantId, evaluationRunId])
  @@index([tenantId, evaluationResultId])
  @@index([tenantId, publicationId])
  @@index([tenantId, retrievalTraceId])
  @@index([tenantId, sourceId])
  @@index([tenantId, v2DocumentRevisionId])
  @@index([tenantId, factId])
  @@index([tenantId, guidanceRuleId])
}

model KnowledgeV2FeedbackEvidence {
  tenantId            String
  corpusKind          KnowledgeCorpusKind @default(STRUCTURED_V2)
  feedbackId          String
  evidenceReferenceId String
  ordinal             Int
  relevanceScore      Float?
  createdAt           DateTime            @default(now())

  tenant            Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  feedback          KnowledgeV2Feedback          @relation(fields: [tenantId, feedbackId, corpusKind], references: [tenantId, id, corpusKind], onDelete: Restrict, onUpdate: NoAction)
  evidenceReference KnowledgeV2EvidenceReference @relation(fields: [tenantId, evidenceReferenceId, corpusKind], references: [tenantId, id, corpusKind], onDelete: Restrict, onUpdate: NoAction)

  @@id([tenantId, feedbackId, evidenceReferenceId])
  @@unique([tenantId, feedbackId, ordinal])
  @@index([tenantId, evidenceReferenceId])
}

model KnowledgeV2RetrievalTrace {
  id                             String                      @id @default(cuid())
  tenantId                       String
  corpusKind                     KnowledgeCorpusKind         @default(STRUCTURED_V2)
  traceKey                       String
  distributedTraceId             String?
  snapshotKind                   KnowledgeV2SnapshotKind
  targetKey                      String                      @default("workspace-v2")
  publicationId                  String?
  candidateId                    String?
  candidateVersion               Int?
  candidateManifestHash          String?
  evaluationRunId                String?
  evaluationResultId             String?
  responseMessageId              String?
  queryHash                      String
  queryHashKeyId                 String?
  queryHashVersion               String?
  restrictedQueryRef             String
  filters                        Json
  filtersHash                    String
  permissionFingerprint          String
  candidateCount                 Int                         @default(0)
  selectedCount                  Int                         @default(0)
  retrievalPolicyVersion         String
  retrievalProcessorPolicyHash   String?
  modelProcessorPolicyHash       String?
  rerankerVersion                String?
  promptPolicyVersion            String
  graphVersion                   String
  provider                       String?
  generatorModel                 String?
  providerOutputHash             String?
  gateInputHash                  String?
  gateResultHash                 String?
  outcome                        KnowledgeV2RetrievalOutcome
  gateOutcome                    KnowledgeV2GateOutcome
  answerHash                     String?
  restrictedTraceRef             String?
  retrievalCandidateManifestHash String
  citationManifestHash           String
  latencyMs                      Int?
  inputTokens                    Int?
  outputTokens                   Int?
  costMicros                     BigInt?
  retentionClass                 String
  retentionExpiresAt             DateTime
  createdAt                      DateTime                    @default(now())

  tenant           Tenant                          @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  publication      KnowledgePublication?           @relation(fields: [tenantId, publicationId, corpusKind], references: [tenantId, id, corpusKind], onDelete: Restrict, onUpdate: NoAction)
  evaluationRun    KnowledgeV2EvaluationRun?       @relation(fields: [tenantId, evaluationRunId, corpusKind], references: [tenantId, id, corpusKind], onDelete: Restrict, onUpdate: NoAction)
  evaluationResult KnowledgeV2EvaluationResult?    @relation(fields: [tenantId, evaluationResultId, evaluationRunId, corpusKind], references: [tenantId, id, evaluationRunId, corpusKind], onDelete: Restrict, onUpdate: NoAction)
  responseMessage  Message?                        @relation(fields: [tenantId, responseMessageId], references: [tenantId, id], onDelete: Restrict, onUpdate: NoAction)
  candidates       KnowledgeV2RetrievalCandidate[]
  citations        KnowledgeV2Citation[]
  feedback         KnowledgeV2Feedback[]

  @@unique([tenantId, traceKey])
  @@unique([tenantId, distributedTraceId])
  @@unique([tenantId, id])
  @@unique([tenantId, id, corpusKind])
  @@index([tenantId, publicationId, createdAt])
  @@index([tenantId, candidateId, candidateVersion])
  @@index([tenantId, evaluationRunId])
  @@index([tenantId, evaluationResultId])
  @@index([tenantId, responseMessageId])
  @@index([tenantId, outcome, gateOutcome, createdAt])
  @@index([retentionExpiresAt])
}

model KnowledgeV2RetrievalCandidate {
  id                  String                               @id @default(cuid())
  tenantId            String
  corpusKind          KnowledgeCorpusKind                  @default(STRUCTURED_V2)
  retrievalTraceId    String
  candidateKey        String
  evidenceReferenceId String
  denseRank           Int?
  denseScore          Float?
  sparseRank          Int?
  sparseScore         Float?
  fusedRank           Int?
  fusedScore          Float?
  rerankRank          Int?
  rerankScore         Float?
  selected            Boolean                              @default(false)
  rejectionReason     KnowledgeV2RetrievalRejectionReason?
  createdAt           DateTime                             @default(now())

  tenant            Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  retrievalTrace    KnowledgeV2RetrievalTrace    @relation(fields: [tenantId, retrievalTraceId, corpusKind], references: [tenantId, id, corpusKind], onDelete: Restrict, onUpdate: NoAction)
  evidenceReference KnowledgeV2EvidenceReference @relation(fields: [tenantId, evidenceReferenceId, corpusKind], references: [tenantId, id, corpusKind], onDelete: Restrict, onUpdate: NoAction)

  @@unique([tenantId, retrievalTraceId, candidateKey])
  @@unique([tenantId, id])
  @@index([tenantId, retrievalTraceId, selected])
  @@index([tenantId, evidenceReferenceId])
  @@index([tenantId, rerankRank])
}

model KnowledgeV2Citation {
  id                  String                     @id @default(cuid())
  tenantId            String
  corpusKind          KnowledgeCorpusKind        @default(STRUCTURED_V2)
  citationKey         String
  retrievalTraceId    String
  evidenceReferenceId String
  ordinal             Int
  claimHash           String
  restrictedClaimRef  String?
  support             KnowledgeV2CitationSupport @default(NOT_ASSESSED)
  confidence          Float?
  toolObservedAt      DateTime?
  toolExpiresAt       DateTime?
  createdAt           DateTime                   @default(now())

  tenant            Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  retrievalTrace    KnowledgeV2RetrievalTrace    @relation(fields: [tenantId, retrievalTraceId, corpusKind], references: [tenantId, id, corpusKind], onDelete: Restrict, onUpdate: NoAction)
  evidenceReference KnowledgeV2EvidenceReference @relation(fields: [tenantId, evidenceReferenceId, corpusKind], references: [tenantId, id, corpusKind], onDelete: Restrict, onUpdate: NoAction)

  @@unique([tenantId, citationKey])
  @@unique([tenantId, retrievalTraceId, ordinal])
  @@unique([tenantId, id])
  @@index([tenantId, evidenceReferenceId])
  @@index([tenantId, support])
}

model KnowledgeJob {
  id                String             @id @default(cuid())
  tenantId          String
  idempotencyKey    String
  stage             String
  pipelineVersion   String             @default("legacy-v1")
  generation        Int                @default(1)
  status            KnowledgeJobStatus @default(QUEUED)
  priority          Int                @default(0)
  deadlineAt        DateTime?
  availableAt       DateTime           @default(now())
  maxAttempts       Int                @default(5)
  attemptCount      Int                @default(0)
  progressCompleted Int                @default(0)
  progressTotal     Int?
  payloadRef        String?
  errorCode         String?
  errorMessage      String?
  traceId           String?
  sourceId          String?
  v2SourceId        String?
  revisionId        String?
  v2RevisionId      String?
  indexSnapshotId   String?
  publicationId     String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  startedAt         DateTime?
  heartbeatAt       DateTime?
  completedAt       DateTime?

  tenant            Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  source            BusinessKnowledgeSource?      @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  v2Source          KnowledgeV2Source?            @relation("KnowledgeV2SourceJobs", fields: [tenantId, v2SourceId], references: [tenantId, id], onDelete: NoAction, onUpdate: NoAction)
  revision          KnowledgeRevision?            @relation(fields: [revisionId], references: [id], onDelete: SetNull)
  v2Revision        KnowledgeV2DocumentRevision?  @relation("KnowledgeV2RevisionJobs", fields: [tenantId, v2SourceId, v2RevisionId], references: [tenantId, sourceId, id], onDelete: NoAction, onUpdate: NoAction)
  indexSnapshot     KnowledgeIndexSnapshot?       @relation(fields: [indexSnapshotId], references: [id], onDelete: SetNull)
  publication       KnowledgePublication?         @relation(fields: [publicationId], references: [id], onDelete: SetNull)
  attempts          KnowledgeJobAttempt[]
  legacyMigration   KnowledgeV2LegacyMigration?
  fileUploadIntents KnowledgeV2FileUploadIntent[]

  @@unique([tenantId, idempotencyKey])
  @@unique([tenantId, id])
  @@index([status, availableAt, priority])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, sourceId, generation])
  @@index([tenantId, v2SourceId, generation])
  @@index([tenantId, v2RevisionId, generation])
}

model KnowledgeJobAttempt {
  id           String                    @id @default(cuid())
  tenantId     String
  jobId        String
  attempt      Int
  status       KnowledgeJobAttemptStatus @default(RUNNING)
  workerId     String?
  errorCode    String?
  errorMessage String?
  traceId      String?
  startedAt    DateTime                  @default(now())
  heartbeatAt  DateTime?
  completedAt  DateTime?

  job KnowledgeJob @relation(fields: [tenantId, jobId], references: [tenantId, id], onDelete: Cascade)

  @@unique([jobId, attempt])
  @@index([tenantId, jobId, status])
  @@index([status, heartbeatAt])
}

model KnowledgeOutbox {
  id               String                @id @default(cuid())
  tenantId         String
  aggregateType    String
  aggregateId      String
  aggregateVersion Int
  eventType        String
  schemaVersion    Int                   @default(1)
  dedupeKey        String
  payload          Json
  status           KnowledgeOutboxStatus @default(PENDING)
  availableAt      DateTime              @default(now())
  deadlineAt       DateTime?
  attemptCount     Int                   @default(0)
  lockedAt         DateTime?
  lockedBy         String?
  publishedAt      DateTime?
  lastErrorCode    String?
  traceId          String?
  traceParent      String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, dedupeKey])
  @@unique([tenantId, aggregateType, aggregateId, aggregateVersion, eventType])
  @@index([status, availableAt, createdAt])
  @@index([tenantId, aggregateType, aggregateId, aggregateVersion])
}

model KnowledgeInbox {
  id           String               @id @default(cuid())
  tenantId     String
  consumer     String
  eventId      String
  status       KnowledgeInboxStatus @default(PROCESSING)
  result       Json?
  errorCode    String?
  attemptCount Int                  @default(1)
  receivedAt   DateTime             @default(now())
  startedAt    DateTime             @default(now())
  completedAt  DateTime?
  updatedAt    DateTime             @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([consumer, eventId])
  @@index([tenantId, status, receivedAt])
  @@index([status, updatedAt])
}

model AiReplyRun {
  id                String           @id @default(cuid())
  tenantId          String
  conversationId    String
  inboundMessageId  String
  replyMessageId    String?
  publicationId     String?
  capabilitySetHash String?
  operationalBindingHash String?
  operationalPermissionGeneration Int?
  capabilityType   KnowledgeV2CapabilityType?
  allowedAutonomy  KnowledgeV2CapabilityAutonomy?
  requiredAutonomy KnowledgeV2CapabilityAutonomy?
  capabilityDecision KnowledgeV2CapabilityDecision?
  replyDisposition KnowledgeV2ReplyDisposition?
  replyContentHash String?
  replyTemplateVersion String?
  idempotencyKey    String
  inputHash         String
  generation        Int
  sequence          Int
  status            AiReplyRunStatus @default(QUEUED)
  schemaVersion     Int              @default(1)
  attemptCount      Int              @default(0)
  maxAttempts       Int              @default(5)
  availableAt       DateTime         @default(now())
  deadlineAt        DateTime?
  payloadRef        String?
  errorCode         String?
  errorMessage      String?
  traceId           String?
  traceParent       String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  startedAt         DateTime?
  heartbeatAt       DateTime?
  cancelRequestedAt DateTime?
  cancelReason      String?
  completedAt       DateTime?

  tenant                        Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation                  Conversation                   @relation(fields: [tenantId, conversationId], references: [tenantId, id], onDelete: NoAction, map: "AiReplyRun_tenant_conversation_fkey")
  inboundMessage                Message                        @relation("AiReplyInputMessage", fields: [tenantId, conversationId, inboundMessageId], references: [tenantId, conversationId, id], onDelete: NoAction, map: "AiReplyRun_tenant_inbound_fkey")
  replyMessage                  Message?                       @relation("AiReplyOutputMessage", fields: [tenantId, conversationId, replyMessageId], references: [tenantId, conversationId, id], onDelete: NoAction, map: "AiReplyRun_tenant_reply_fkey")
  publication                   KnowledgePublication?          @relation(fields: [tenantId, publicationId, capabilitySetHash, operationalBindingHash, operationalPermissionGeneration], references: [tenantId, id, capabilitySetHash, operationalBindingHash, operationalPermissionGeneration], onDelete: NoAction, onUpdate: NoAction, map: "AiReplyRun_tenant_publication_fkey")
  runtimeCapability             KnowledgePublicationCapability? @relation("AiReplyRuntimeCapability", fields: [tenantId, publicationId, capabilityType, allowedAutonomy], references: [tenantId, publicationId, capabilityType, allowedAutonomy], onDelete: NoAction, onUpdate: NoAction, map: "AiReplyRun_runtimeCapability_fkey")
  externalOperations            ExternalOperation[]
  knowledgeV2LiveToolExecutions KnowledgeV2LiveToolExecution[]

  @@unique([tenantId, idempotencyKey])
  @@unique([tenantId, inboundMessageId])
  @@unique([tenantId, replyMessageId])
  @@unique([tenantId, conversationId, replyMessageId])
  @@unique([conversationId, sequence])
  @@unique([tenantId, id])
  @@unique([tenantId, id, conversationId, inboundMessageId], map: "AiReplyRun_liveToolContext_key")
  @@index([status, availableAt, createdAt])
  @@index([tenantId, conversationId, generation, sequence])
  @@index([tenantId, publicationId])
}

model KnowledgeV2LiveToolExecution {
  id                          String   @id
  executionKey                String
  tenantId                    String
  aiReplyRunId                String
  conversationId              String
  originatingMessageId        String
  leadId                      String?
  executionContextId          String
  attemptNumber               Int
  toolCallId                  String
  toolKey                     String
  toolVersion                 String
  safeName                    String
  sourceSystem                String
  operationalCategory         String
  toolPolicyVersion           String
  queryHash                   String
  queryHashKeyId              String?
  queryHashVersion            String?
  requestHash                 String
  authorizationScopeHash      String
  authorizationDecisionId     String
  permissionGeneration        Int
  connectionId                String?
  connectionPermissionVersion Int?
  customerIdentityId          String?
  customerIdentityVersion     Int?
  subjectHash                 String
  resultType                  String
  valueHash                   String
  exactValueHash              String
  contentHash                 String
  envelopeHash                String
  payloadObjectKey            String
  payloadEncryptionKeyRef     String
  payloadHash                 String
  payloadBytes                Int
  observedAt                  DateTime
  expiresAt                   DateTime
  authorizedAt                DateTime
  authorizationExpiresAt      DateTime
  retentionExpiresAt          DateTime
  createdAt                   DateTime @default(now())

  tenant             Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  aiReplyRun         AiReplyRun                     @relation(fields: [tenantId, aiReplyRunId, conversationId, originatingMessageId], references: [tenantId, id, conversationId, inboundMessageId], onDelete: Restrict, onUpdate: NoAction)
  conversation       Conversation                   @relation(fields: [tenantId, conversationId], references: [tenantId, id], onDelete: Restrict, onUpdate: NoAction)
  originatingMessage Message                        @relation("KnowledgeV2LiveToolOriginatingMessage", fields: [tenantId, conversationId, originatingMessageId], references: [tenantId, conversationId, id], onDelete: Restrict, onUpdate: NoAction)
  lead               Lead?                          @relation(fields: [tenantId, leadId], references: [tenantId, id], onDelete: Restrict, onUpdate: NoAction)
  connection         IntegrationAccount?            @relation(fields: [tenantId, connectionId], references: [tenantId, id], onDelete: Restrict, onUpdate: NoAction)
  customerIdentity   AuthenticatedCustomerIdentity? @relation(fields: [tenantId, customerIdentityId], references: [tenantId, id], onDelete: Restrict, onUpdate: NoAction)
  evidenceReferences KnowledgeV2EvidenceReference[]

  @@unique([tenantId, executionKey])
  @@unique([tenantId, id])
  @@unique([payloadObjectKey])
  @@index([tenantId, aiReplyRunId, attemptNumber])
  @@index([tenantId, conversationId, createdAt])
  @@index([tenantId, connectionId, connectionPermissionVersion])
  @@index([tenantId, customerIdentityId, customerIdentityVersion])
  @@index([tenantId, operationalCategory, createdAt])
  @@index([tenantId, authorizationDecisionId])
  @@index([expiresAt])
  @@index([retentionExpiresAt])
}

model ExternalOperation {
  id                     String                  @id
  tenantId               String
  aiReplyRunId           String?
  conversationId         String?
  originatingMessageId   String?
  integrationId          String?
  operationKind          String
  requestHash            String
  confirmationVersion    Int                     @default(1)
  status                 ExternalOperationStatus @default(REQUESTED)
  providerIdempotencyKey String?
  externalReference      String?
  result                 Json?
  errorCode              String?
  errorMessage           String?
  attemptCount           Int                     @default(0)
  deadlineAt             DateTime?
  nextRetryAt            DateTime?
  retentionExpiresAt     DateTime
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  startedAt              DateTime?
  completedAt            DateTime?
  reconciledAt           DateTime?

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  aiReplyRun         AiReplyRun?         @relation(fields: [tenantId, aiReplyRunId], references: [tenantId, id], onDelete: NoAction, map: "ExternalOperation_tenant_run_fkey")
  conversation       Conversation?       @relation(fields: [tenantId, conversationId], references: [tenantId, id], onDelete: NoAction, map: "ExternalOperation_tenant_conversation_fkey")
  originatingMessage Message?            @relation("ExternalOperationOriginatingMessage", fields: [tenantId, originatingMessageId], references: [tenantId, id], onDelete: NoAction, map: "ExternalOperation_tenant_message_fkey")
  integration        IntegrationAccount? @relation(fields: [tenantId, integrationId], references: [tenantId, id], onDelete: NoAction, map: "ExternalOperation_tenant_integration_fkey")

  @@index([tenantId, status, nextRetryAt])
  @@index([tenantId, aiReplyRunId])
  @@index([tenantId, conversationId, originatingMessageId], map: "ExternalOperation_origin_idx")
  @@index([tenantId, integrationId, operationKind])
  @@index([status, retentionExpiresAt])
}

model ChannelDeliveryOperation {
  id                     String                  @id
  tenantId               String
  messageId              String
  conversationId         String
  channelId              String
  provider               String
  channelKey             String
  recipientKey           String
  deliveryVersion        Int                     @default(1)
  requestHash            String
  status                 ExternalOperationStatus @default(REQUESTED)
  providerIdempotencyKey String?
  providerMessageId      String?
  result                 Json?
  errorCode              String?
  errorMessage           String?
  attemptCount           Int                     @default(0)
  deadlineAt             DateTime?
  nextRetryAt            DateTime?
  retentionExpiresAt     DateTime
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  startedAt              DateTime?
  completedAt            DateTime?
  reconciledAt           DateTime?

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  message      Message      @relation(fields: [tenantId, conversationId, messageId], references: [tenantId, conversationId, id], onDelete: NoAction, map: "ChannelDeliveryOperation_tenant_message_fkey")
  conversation Conversation @relation(fields: [tenantId, conversationId, channelId], references: [tenantId, id, channelId], onDelete: NoAction, map: "ChannelDeliveryOperation_tenant_conversation_fkey")
  channel      Channel      @relation(fields: [tenantId, channelId], references: [tenantId, id], onDelete: NoAction, map: "ChannelDeliveryOperation_tenant_channel_fkey")

  @@unique([tenantId, messageId, channelKey, recipientKey, deliveryVersion], map: "ChannelDeliveryOperation_deliveryIdentity_key")
  @@index([tenantId, status, nextRetryAt])
  @@index([tenantId, conversationId, createdAt])
  @@index([tenantId, channelId, provider])
  @@index([provider, providerMessageId])
  @@index([status, retentionExpiresAt])
}

model RuntimeOutbox {
