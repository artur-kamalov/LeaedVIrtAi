  feedback         KnowledgeV2Feedback?            @relation(fields: [tenantId, feedbackId, corpusKind], references: [tenantId, id, corpusKind], onDelete: Restrict, onUpdate: NoAction)
  publication      KnowledgePublication?           @relation(fields: [tenantId, publicationId, corpusKind], references: [tenantId, id, corpusKind], onDelete: Restrict, onUpdate: NoAction)
