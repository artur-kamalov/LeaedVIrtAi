{
  "name": "@leadvirt/db",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "tsx prisma/apply-migration.ts",
    "db:push": "prisma db push --schema prisma/schema.prisma",
    "db:validate": "prisma validate --schema prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:cleanup:pilot": "tsx prisma/cleanup-pilot.ts",
    "qa:snapshot-authorization-race": "tsx prisma/knowledge-v2-snapshot-authorization-race-smoke.ts",
    "qa:capability-snapshot-migration": "tsx ../../artifacts/scripts/knowledge-v2-capability-snapshot-migration-smoke.ts",
    "qa:validation-history-migration": "tsx prisma/knowledge-v2-validation-history-migration-smoke.ts",
    "qa:tenant-context": "tsx prisma/tenant-transaction-context-smoke.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.3",
    "prisma": "^6.9.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
