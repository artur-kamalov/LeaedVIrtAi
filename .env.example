# LeadVirt.ai environment example

# App
NODE_ENV=development
APP_ENV=local
APP_URL=http://localhost:3001
API_URL=http://localhost:4001
PUBLIC_APP_NAME=LeadVirt.ai

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4001/api
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_WEB_URL=http://localhost:3001
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_TELEGRAM_LOGIN_BOT=

# Backend
PORT=4001
CORS_ORIGINS=http://localhost:3001
LOG_LEVEL=debug

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/leadvirt?schema=public

# Redis / queues
REDIS_URL=redis://localhost:6380
REDIS_HOST_PORT=6380

# Auth
AUTH_MODE=mock
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
JWT_SECRET=dev-change-me
JWT_REFRESH_SECRET=dev-change-me-too
AUTH_COOKIE_SECURE=false
AUTH_2FA_ENCRYPTION_KEY=dev-change-me-for-totp-secret-encryption
AUTH_RATE_LIMIT_DISABLED=false
AUTH_IDENTIFIER_POLICY=ru
AUTH_STAFF_EMAIL_DOMAINS=leadvirt.ai
AUTH_EXTRA_ALLOWED_EMAIL_DOMAINS=
AUTH_CREDENTIALS_ENABLED=true

# Encryption
ENCRYPTION_KEY=dev-32-byte-key-change-in-production

# AI
AI_PROVIDER=openai
AI_DEFAULT_MODEL=gpt-5.5
AI_REASONING_EFFORT=low
AI_VERBOSITY=low
AI_REPLY_MODE=sync
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_ENABLE_REAL_PROVIDER=false
AI_TENANT_DAILY_TOKEN_BUDGET=0
AI_TENANT_MONTHLY_TOKEN_BUDGET=0

# RAG / vector search
RAG_QDRANT_ENABLED=false
RAG_QDRANT_URL=http://localhost:6333
RAG_QDRANT_API_KEY=
RAG_QDRANT_COLLECTION=leadvirt_knowledge
QDRANT_HOST_PORT=6333

# Storage
STORAGE_PROVIDER=local
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=leadvirt-dev
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# Email
EMAIL_PROVIDER=mock
EMAIL_FROM=LeadVirt.ai <noreply@leadvirt.ai>

# Billing
BILLING_MODE=manual
BILLING_PROVIDER=manual
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Integrations
TELEGRAM_BOT_TOKEN=
TELEGRAM_LOGIN_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=demo-telegram-secret
GENERIC_WEBHOOK_SECRET=demo-webhook-secret

# Observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
WORKER_METRICS_ENABLED=true
WORKER_METRICS_PORT=4002
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Feature flags
FEATURE_REALTIME=true
FEATURE_BILLING=false
FEATURE_AI_REAL_PROVIDER=false
FEATURE_TELEGRAM=true
FEATURE_WEBSITE_WIDGET=true

# Worker
# Set AI_REPLY_MODE=queue and WORKER_ENABLE_PROCESSORS=true to process AI replies through BullMQ.
WORKER_ENABLE_PROCESSORS=false
WORKER_JOB_TIMEOUT_MS=30000
WORKER_DLQ_INSPECT_LIMIT=20
