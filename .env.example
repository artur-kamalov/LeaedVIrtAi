# LeadVirt.ai environment example

# App
NODE_ENV=development
APP_ENV=local
APP_URL=http://localhost:3001
API_URL=http://localhost:4001
PUBLIC_APP_NAME=LeadVirt.ai

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4001/api
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_WEB_URL=http://localhost:3001
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_TELEGRAM_LOGIN_BOT=
# Optional external sales page. When empty, Corporate uses the normal signup and billing request flow.
NEXT_PUBLIC_CORPORATE_CONTACT_URL=

# Backend
PORT=4001
CORS_ORIGINS=http://localhost:3001
LOG_LEVEL=debug

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/leadvirt?schema=public

# Redis / queues
# redis:// and rediss:// default to port 6379; rediss:// enables TLS. Keep local 6380 explicit.
REDIS_URL=redis://localhost:6380
REDIS_HOST_PORT=6380

# Auth
AUTH_MODE=mock
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
JWT_SECRET=dev-change-me
JWT_REFRESH_SECRET=dev-change-me-too
AUTH_COOKIE_SECURE=false
AUTH_2FA_ENCRYPTION_KEY=dev-change-me-for-totp-secret-encryption
AUTH_RATE_LIMIT_DISABLED=false
AUTH_IDENTIFIER_POLICY=ru
AUTH_STAFF_EMAIL_DOMAINS=leadvirt.ai
AUTH_EXTRA_ALLOWED_EMAIL_DOMAINS=
AUTH_CREDENTIALS_ENABLED=true
AUTH_EMAIL_OTP_ENABLED=true
AUTH_EMAIL_OTP_PEPPER=dev-change-me-use-at-least-32-random-characters

# Encryption
ENCRYPTION_KEY=dev-32-byte-key-change-in-production
INTEGRATION_CREDENTIALS_ENCRYPTION_KEY=dev-integration-credentials-key-change-in-production
CUSTOMER_IDENTITY_HMAC_KEY=dev-customer-identity-hmac-key-change-in-production

# Telegram
TELEGRAM_BOT_API_BASE_URL=https://api.telegram.org
TELEGRAM_WEBHOOK_BASE_URL=http://localhost:4001/api/public/channels/telegram

# AI
AI_PROVIDER=openai
AI_DEFAULT_MODEL=gpt-5.5
AI_REASONING_EFFORT=low
AI_VERBOSITY=low
AI_REPLY_MODE=queue
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_ENABLE_REAL_PROVIDER=false
AI_TENANT_DAILY_TOKEN_BUDGET=0
AI_TENANT_MONTHLY_TOKEN_BUDGET=0

# RAG / vector search
RAG_RETRIEVAL_MODE=database
RAG_QDRANT_ENABLED=false
RAG_QDRANT_URL=http://localhost:6333
RAG_QDRANT_API_KEY=
RAG_QDRANT_COLLECTION=leadvirt_knowledge
RAG_QDRANT_TIMEOUT_MS=3000
RAG_MIN_SCORE=0.05
RAG_CANDIDATE_LIMIT=50
KNOWLEDGE_V2_EMBEDDING_MODEL=text-embedding-3-small
KNOWLEDGE_V2_EMBEDDING_DIMENSIONS=1536
KNOWLEDGE_V2_EMBEDDING_BATCH_SIZE=64
KNOWLEDGE_V2_EMBEDDING_TIMEOUT_MS=30000
KNOWLEDGE_V2_EMBEDDING_DEPLOYMENT=unconfigured
KNOWLEDGE_V2_EMBEDDING_REGION=unconfigured
KNOWLEDGE_V2_EMBEDDING_POLICY_VERSION=external-embedding-v1
KNOWLEDGE_V2_RETRIEVAL_POLICY_VERSION=external-retrieval-v1
KNOWLEDGE_V2_QUERY_EMBEDDING_MAX_CLASSIFICATION=INTERNAL
KNOWLEDGE_V2_RERANKER_MAX_CLASSIFICATION=INTERNAL
KNOWLEDGE_V2_EXTERNAL_EMBEDDING_MAX_CLASSIFICATION=INTERNAL
KNOWLEDGE_V2_SPARSE_MAX_NON_ZERO=2048
KNOWLEDGE_V2_EMBEDDING_CACHE_TTL_DAYS=30
KNOWLEDGE_V2_RERANKER_APPROVED=false
KNOWLEDGE_V2_RERANKER_ENDPOINT=
KNOWLEDGE_V2_RERANKER_API_KEY=
KNOWLEDGE_V2_RERANKER_PROVIDER=unconfigured
KNOWLEDGE_V2_RERANKER_MODEL=unconfigured
KNOWLEDGE_V2_RERANKER_VERSION=unconfigured
KNOWLEDGE_V2_RERANKER_REGION=unconfigured
KNOWLEDGE_V2_RERANKER_TIMEOUT_MS=5000
KNOWLEDGE_V2_GROUNDED_ANSWER_APPROVED=false
KNOWLEDGE_V2_GROUNDED_ANSWER_BASE_URL=
KNOWLEDGE_V2_GROUNDED_ANSWER_API_KEY=
KNOWLEDGE_V2_GROUNDED_ANSWER_PROVIDER=unconfigured
KNOWLEDGE_V2_GROUNDED_ANSWER_MODEL=unconfigured
KNOWLEDGE_V2_GROUNDED_ANSWER_VERSION=unconfigured
KNOWLEDGE_V2_GROUNDED_ANSWER_REGION=unconfigured
KNOWLEDGE_V2_MODEL_PROCESSOR_POLICY_VERSION=external-model-v1
KNOWLEDGE_V2_GROUNDED_PROMPT_POLICY_VERSION=grounded-answer-v1
KNOWLEDGE_V2_MODEL_PROCESSOR_MAX_CLASSIFICATION=INTERNAL
KNOWLEDGE_V2_GROUNDED_ANSWER_TIMEOUT_MS=20000
KNOWLEDGE_REAL_PROVIDER_GATE_ENABLED=false
KNOWLEDGE_REAL_PROVIDER_API_BASE=http://localhost:4001/api
KNOWLEDGE_REAL_PROVIDER_API_HOST_ALLOWLIST=localhost
KNOWLEDGE_REAL_PROVIDER_API_ALLOW_HTTP=true
KNOWLEDGE_REAL_PROVIDER_API_REQUEST_TIMEOUT_MS=30000
KNOWLEDGE_REAL_PROVIDER_EMAIL=
KNOWLEDGE_REAL_PROVIDER_PASSWORD=
KNOWLEDGE_REAL_PROVIDER_SOURCE_IDS=
KNOWLEDGE_REAL_PROVIDER_EXPECTED_TEST_SET_HASH=
KNOWLEDGE_REAL_PROVIDER_TIMEOUT_MS=900000
KNOWLEDGE_REAL_PROVIDER_POLICY_PATH=artifacts/evals/knowledge-v2-real-provider-gate.json
KNOWLEDGE_REAL_PROVIDER_REPORT_PATH=artifacts/reports/knowledge-v2-real-provider-gate.json
KNOWLEDGE_EMBEDDING_PROVIDER_APPROVED=false
KNOWLEDGE_WEBSITE_IMPORT_ENABLED=false
KNOWLEDGE_WEBSITE_EGRESS_READY=false
KNOWLEDGE_OBJECT_STORE_PATH=
KNOWLEDGE_ARTIFACT_ENCRYPTION_KEY=
KNOWLEDGE_ARTIFACT_ENCRYPTION_KEY_ID=knowledge-artifact-v1
KNOWLEDGE_QUERY_HMAC_ACTIVE_KEY_ID=
KNOWLEDGE_QUERY_HMAC_KEYS=
KNOWLEDGE_MAX_WEBSITE_BYTES=2097152
KNOWLEDGE_WEBSITE_FETCH_TIMEOUT_MS=10000
KNOWLEDGE_FILE_IMPORT_ENABLED=false
KNOWLEDGE_MAX_FILE_BYTES=10485760
KNOWLEDGE_FILE_UPLOAD_TTL_SECONDS=600
KNOWLEDGE_FILE_UPLOAD_STREAM_TIMEOUT_MS=30000
KNOWLEDGE_FILE_SCANNER_APPROVED=false
KNOWLEDGE_FILE_SCANNER_HOST=
KNOWLEDGE_FILE_SCANNER_PORT=3310
KNOWLEDGE_FILE_SCANNER_VERSION=clamav
KNOWLEDGE_FILE_SCANNER_TIMEOUT_MS=10000
QDRANT_HOST_PORT=6333

# Storage
STORAGE_PROVIDER=local
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=leadvirt-dev
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# Email
EMAIL_PROVIDER=mock
EMAIL_OTP_PROVIDER=mock
EMAIL_FROM=LeadVirt.ai <noreply@leadvirt.com>
BILLING_REQUEST_EMAIL=
SMTP_HOST=smtp.beget.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@leadvirt.com
SMTP_PASSWORD=
SMTP_FROM_NAME=LeadVirt.ai
SMTP_FROM_EMAIL=noreply@leadvirt.com
UNISENDER_API_URL=https://api.unisender.com/ru/api/sendEmail
UNISENDER_API_KEY=
UNISENDER_LIST_ID=
UNISENDER_SENDER_NAME=LeadVirt.ai
UNISENDER_SENDER_EMAIL=noreply@leadvirt.com

# Billing
BILLING_MODE=manual
BILLING_PROVIDER=manual
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Integrations
TELEGRAM_BOT_TOKEN=
TELEGRAM_LOGIN_BOT_TOKEN=
TELEGRAM_LOGIN_BOT_ID=
TELEGRAM_WEBHOOK_SECRET=demo-telegram-secret
GENERIC_WEBHOOK_SECRET=demo-webhook-secret

# Observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
WORKER_METRICS_ENABLED=true
WORKER_METRICS_PORT=4002
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
OTEL_COLLECTOR_HEALTH_URL=http://localhost:13133
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Feature flags
FEATURE_REALTIME=true
FEATURE_BILLING=false
FEATURE_AI_REAL_PROVIDER=false
FEATURE_TELEGRAM=true
FEATURE_WEBSITE_WIDGET=true

# Worker
# Keep WORKER_ENABLE_PROCESSORS=true to process AI replies through BullMQ.
WORKER_ENABLE_PROCESSORS=false
WORKER_JOB_TIMEOUT_MS=30000
WORKER_DLQ_INSPECT_LIMIT=20
