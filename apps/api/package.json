{
  "name": "@leadvirt/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/apps/api/src/main.js",
    "lint": "eslint .",
    "qa:auth:email-otp": "tsx ../../artifacts/scripts/email-otp-auth-smoke.ts",
    "qa:auth:team-security": "tsx ../../artifacts/scripts/settings-team-security-smoke.ts",
    "qa:settings:api-key-truthful-state": "tsx ../../artifacts/scripts/settings-api-key-truthful-state-smoke.ts",
    "qa:auth:smtp-contract": "tsx ../../artifacts/scripts/smtp-email-otp-contract-smoke.ts",
    "qa:auth:unisender-contract": "tsx ../../artifacts/scripts/unisender-email-otp-contract-smoke.ts",
    "qa:automation:truthfulness": "tsx ../../artifacts/scripts/workflow-runtime-truthfulness-smoke.ts",
    "qa:billing:service": "tsx ../../artifacts/scripts/billing-service-smoke.ts",
    "qa:ai:provider": "tsx ../../artifacts/scripts/ai-provider-smoke.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@leadvirt/ai": "workspace:*",
    "@leadvirt/config": "workspace:*",
    "@leadvirt/db": "workspace:*",
    "@leadvirt/integrations": "workspace:*",
    "@leadvirt/knowledge": "workspace:*",
    "@leadvirt/observability": "workspace:*",
    "@leadvirt/runtime-queue": "workspace:*",
    "@leadvirt/types": "workspace:*",
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.3",
    "@nestjs/platform-express": "^11.1.3",
    "bullmq": "5.56.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "nodemailer": "9.0.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.3",
    "@types/nodemailer": "8.0.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
