{
  "name": "leadvirt",
  "private": true,
  "version": "0.1.0",
  "description": "LeadVirt.ai scalable modular monolith workspace",
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "dev": "corepack pnpm --parallel --filter @leadvirt/web --filter @leadvirt/api --filter @leadvirt/worker dev",
    "dev:web": "corepack pnpm --filter @leadvirt/web dev",
    "dev:api": "corepack pnpm --filter @leadvirt/api dev",
    "dev:worker": "corepack pnpm --filter @leadvirt/worker dev",
    "build": "corepack pnpm -r --if-present build",
    "lint": "corepack pnpm -r --if-present lint",
    "typecheck": "corepack pnpm -r --if-present typecheck",
    "qa:visual": "corepack pnpm dlx @playwright/test test artifacts/playwright/visual-check.spec.ts --reporter=line --workers=1",
    "qa:api": "corepack pnpm dlx @playwright/test test artifacts/playwright/demo-data-boundary.spec.ts artifacts/playwright/clean-user-data-separation.spec.ts artifacts/playwright/auth-flow.spec.ts artifacts/playwright/onboarding-api.spec.ts artifacts/playwright/dashboard-api.spec.ts artifacts/playwright/analytics-api.spec.ts artifacts/playwright/integrations-api.spec.ts artifacts/playwright/automation-api.spec.ts artifacts/playwright/settings-api.spec.ts artifacts/playwright/channels-widget-settings.spec.ts artifacts/playwright/billing-api.spec.ts artifacts/playwright/widget-api.spec.ts artifacts/playwright/inbox-empty-state.spec.ts artifacts/playwright/inbox-actions.spec.ts artifacts/playwright/social-intake-visibility.spec.ts artifacts/playwright/webhook-widget-intake-visibility.spec.ts artifacts/playwright/conversation-send.spec.ts artifacts/playwright/conversation-actions.spec.ts artifacts/playwright/conversation-status-actions.spec.ts artifacts/playwright/conversation-ai-draft.spec.ts artifacts/playwright/conversation-events-timeline.spec.ts artifacts/playwright/conversation-export.spec.ts artifacts/playwright/pipeline-actions.spec.ts artifacts/playwright/product-layout-identity.spec.ts --reporter=line --workers=1",
    "qa:pilot:intake": "corepack pnpm dlx @playwright/test test artifacts/playwright/pilot-real-intake-api.spec.ts --reporter=line --workers=1",
    "qa:pilot:public": "corepack pnpm dlx @playwright/test test artifacts/playwright/pilot-public-url-preflight.spec.ts --reporter=line --workers=1",
    "qa:channels:provisioning": "node artifacts/scripts/channel-provisioning.mjs",
    "provision:webhook-channel": "node artifacts/scripts/provision-webhook-channel.mjs",
    "qa:auth:guard": "node artifacts/scripts/auth-temporary-password-guard.mjs",
    "qa:auth:rate-limit": "node artifacts/scripts/auth-rate-limit.mjs",
    "qa:auth:identifier-policy": "node artifacts/scripts/auth-identifier-policy.mjs",
    "qa:auth:telegram": "node artifacts/scripts/auth-telegram-smoke.mjs",
    "qa:auth:staging-ready": "node artifacts/scripts/auth-staging-ready.mjs",
    "qa:ai:provider": "corepack pnpm --filter @leadvirt/api qa:ai:provider",
    "qa:ai:graph": "corepack pnpm --filter @leadvirt/worker exec tsx ../../artifacts/scripts/ai-reply-graph-smoke.ts",
    "qa:ai:queue-routing": "corepack pnpm --filter @leadvirt/api exec tsx ../../artifacts/scripts/ai-queue-routing-smoke.ts",
    "qa:ai:public-loop": "corepack pnpm --filter @leadvirt/worker exec tsx ../../artifacts/scripts/ai-public-loop-smoke.ts",
    "qa:ai:acceptance": "corepack pnpm --filter @leadvirt/worker exec tsx ../../artifacts/scripts/ai-clean-telegram-acceptance.ts",
    "qa:ai:quality": "corepack pnpm --filter @leadvirt/worker exec tsx ../../artifacts/scripts/ai-quality-gate.ts",
    "qa:ai:budget": "corepack pnpm --filter @leadvirt/worker exec tsx ../../artifacts/scripts/ai-budget-guard-smoke.ts",
    "qa:ai:isolation": "corepack pnpm --filter @leadvirt/api exec tsx ../../artifacts/scripts/ai-tenant-isolation-smoke.ts",
    "qa:ai:qdrant-isolation": "corepack pnpm --filter @leadvirt/api exec tsx ../../artifacts/scripts/ai-qdrant-isolation-smoke.ts",
    "qa:ai:real-eval": "corepack pnpm --filter @leadvirt/worker exec tsx ../../artifacts/scripts/ai-real-provider-eval.ts",
    "qa:channels:delivery": "corepack pnpm --filter @leadvirt/worker exec tsx ../../artifacts/scripts/channel-send-message-smoke.ts",
    "qa:worker:dlq": "corepack pnpm --filter @leadvirt/worker exec tsx ../../artifacts/scripts/worker-dlq-smoke.ts",
    "worker:dlq:inspect": "corepack pnpm --filter @leadvirt/worker exec tsx ../../artifacts/scripts/worker-dlq-inspect.ts",
    "qa:pii:redaction": "corepack pnpm --filter @leadvirt/api exec tsx ../../artifacts/scripts/pii-redaction-smoke.ts",
    "qa:rbac:knowledge": "corepack pnpm --filter @leadvirt/api exec tsx ../../artifacts/scripts/rbac-knowledge-smoke.ts",
    "qa:rbac:channels": "corepack pnpm --filter @leadvirt/api exec tsx ../../artifacts/scripts/rbac-channels-smoke.ts",
    "qa:rbac:product-matrix": "corepack pnpm --filter @leadvirt/api exec tsx ../../artifacts/scripts/rbac-product-matrix-smoke.ts",
    "qa:ai:tool-abac": "corepack pnpm --filter @leadvirt/worker exec tsx ../../artifacts/scripts/ai-tool-abac-smoke.ts",
    "qa:ai:audit": "corepack pnpm --filter @leadvirt/api exec tsx ../../artifacts/scripts/ai-audit-smoke.ts",
    "qa:ai:audit-ui": "corepack pnpm dlx @playwright/test test artifacts/playwright/ai-audit-api.spec.ts --reporter=line --workers=1",
    "qa:ai:eval-redaction": "corepack pnpm --filter @leadvirt/api exec tsx ../../artifacts/scripts/ai-eval-redaction-smoke.ts",
    "qa:demo-boundary": "node artifacts/scripts/check-demo-boundary.mjs",
    "pilot:doctor": "node artifacts/scripts/pilot-doctor.mjs",
    "pilot:packet": "node artifacts/scripts/pilot-packet.mjs",
    "pilot:ready": "node artifacts/scripts/pilot-ready.mjs",
    "release:public-ready": "node artifacts/scripts/public-release-ready.mjs",
    "qa:all": "corepack pnpm run qa:api && corepack pnpm run qa:visual",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml,css,prisma}\"",
    "db:generate": "corepack pnpm --filter @leadvirt/db db:generate",
    "db:migrate": "corepack pnpm --filter @leadvirt/db db:migrate",
    "db:push": "corepack pnpm --filter @leadvirt/db db:push",
    "db:validate": "corepack pnpm --filter @leadvirt/db db:validate",
    "db:seed": "corepack pnpm --filter @leadvirt/db db:seed",
    "db:cleanup:pilot": "corepack pnpm --filter @leadvirt/db db:cleanup:pilot"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@next/eslint-plugin-next": "15.5.19",
    "eslint": "^9.29.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1"
  }
}
